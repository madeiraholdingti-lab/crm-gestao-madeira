        },
        "options": { "timeout": 30000 }
      },
      "id": "node-fwd-conectwhat",
      "name": "→ conect-what (legado)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [320, 120],
